pipeline {
    agent any

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/arbaj0919/Portfolio_1.git'
            }
        }

        stage('Build') {
            steps {
                echo 'Building project...'
                bat 'dir'
            }
        }

        stage('Test') {
            steps {
                echo 'Testing project...'
                bat '''
                IF NOT EXIST index.html (
                    echo index.html missing!
                    exit /b 1
                )
                '''
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploying project...'
            }
        }
    }
}
